{
  "compilerOptions": {
    "module": "esnext",
    "target": "es2023",
    "moduleResolution": "bundler",
    "rootDir": "./",
    "outDir": "./dist",
    "types": [
      "node"
    ],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "catchAsyncs.ts"
  ]
}