{
  "compilerOptions": {
    "module": "esnext",
    "target": "es2023",
    "moduleResolution": "bundler",
    "rootDir": "./",
    "outDir": "./dist",
    "types": [
      "node"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*",
    "src/types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}